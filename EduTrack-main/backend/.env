# EduTrack Backend – Environment Variables
# Copy this file to .env and fill in your actual values.
# Do NOT commit this file to version control.

# Flask
FLASK_DEBUG=true

# Security
SECRET_KEY=edutrack-dev-secret-key-change-in-production
JWT_SECRET_KEY=edutrack-dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_HOURS=8

# MongoDB
MONGO_URI=mongodb+srv://studyybugg_db_user:studyy1997@cluster0.g2hvglv.mongodb.net/
MONGO_DB_NAME=EduTrackDB

# CORS – comma-separated list of allowed origins (use * for all)
CORS_ORIGINS=http://localhost:5173
