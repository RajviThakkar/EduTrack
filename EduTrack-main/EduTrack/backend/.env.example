# EduTrack Backend – Environment Variables Template
# Copy this file to .env and replace placeholder values with your actual secrets.
# This file is safe to commit to version control.

# Flask
FLASK_DEBUG=true

# Security – replace with strong random strings in production
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_HOURS=8

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB_NAME=edutrack

# Backend selection: mongo | mysql | both
DB_BACKEND=both

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=edutrack
MYSQL_AUTO_INIT_SCHEMA=true

# CORS – comma-separated list of allowed frontend origins (use * for all)
CORS_ORIGINS=http://localhost:5173
